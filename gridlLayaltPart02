<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <style>
        .container{
            display: grid;
            grid-template-columns: 1fr 3fr;
            grid-template-rows: auto 1fr;

        }
        .header{
            grid-column: 1 / -1;/*vai dizer qie o header ten que ocupar toda a linha*/
            background-color: aqua;
            padding: 20px;

        }
        .sidebar{
            background-color: rgb(208, 255, 0);
            padding: 20px;

        }
        .content{
            background-color: rgb(105, 49, 65);
            padding: 20px;
        }
        .repet{
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            
        }
        p{
            border: 2px solid rebeccapurple;
            padding: 20px;
        
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">Cabeçalho</div>
        <aside class="sidebar"Barra lateral>Barra lateral</aside>
        <main class="content">Conteúdo Principal</main>
        <main class="repet">
            <p>repeat</p><p>repeat</p><p>repeat</p>
        </main>
    </div>
</body>
</html>
